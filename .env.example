
# CSM Smart Connect Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database Connection
# Format: postgresql://username:password@hostname:port/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/csm_smart_connect

# Individual Database Components (for Replit or other services)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=csm_smart_connect

# Database SSL Configuration (set to 'require' for production)
POSTGRES_SSL=disable

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment Mode (development, production, staging)
NODE_ENV=development

# Server Configuration
PORT=5000
HOST=0.0.0.0

# Application URLs
CLIENT_URL=http://localhost:5000
SERVER_URL=http://localhost:5000

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================

# Session Secret (IMPORTANT: Use a strong, unique secret for production)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-super-secure-session-secret-change-this-in-production

# Session Configuration
SESSION_MAX_AGE=604800000  # 7 days in milliseconds
SESSION_SECURE=false       # Set to true for HTTPS in production
SESSION_SAME_SITE=lax      # CSRF protection

# =============================================================================
# SOCIAL MEDIA INTEGRATIONS
# =============================================================================

# Ayrshare API Configuration
# Get your API key from: https://app.ayrshare.com/
AYRSHARE_API_KEY=your-ayrshare-api-key-here
AYRSHARE_BASE_URL=https://app.ayrshare.com/api

# Social Media Platform Settings
AYRSHARE_DEFAULT_PLATFORMS=twitter,linkedin,facebook

# =============================================================================
# AI INTEGRATIONS
# =============================================================================

# Google Gemini AI Configuration
# Get your API key from: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Gemini Model Configuration
GEMINI_MODEL=gemini-pro
GEMINI_MAX_TOKENS=1000
GEMINI_TEMPERATURE=0.7

# =============================================================================
# SUPABASE CONFIGURATION (if using Supabase)
# =============================================================================

# Supabase Project Configuration
# Get these from your Supabase project dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =============================================================================
# EXTERNAL SERVICE INTEGRATIONS
# =============================================================================

# Email Service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# File Storage (if using AWS S3 or similar)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================

# Google Analytics (optional)
GA_TRACKING_ID=UA-XXXXXXXXX-X

# Application Monitoring
SENTRY_DSN=your-sentry-dsn-url

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# CORS Configuration
CORS_ORIGIN=http://localhost:5000
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100    # Max requests per window

# JWT Configuration (if using JWT)
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=7d

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/Disable Features
FEATURE_SOCIAL_MEDIA=true
FEATURE_AI_SUGGESTIONS=true
FEATURE_TEAM_COLLABORATION=true
FEATURE_ANALYTICS=true

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Debug Logging
DEBUG=express:*,app:*
LOG_LEVEL=debug

# Development Tools
VITE_DEV_SERVER_PORT=5173
BROWSER=chrome

# =============================================================================
# PRODUCTION OPTIMIZATIONS
# =============================================================================

# Compression and Caching
ENABLE_COMPRESSION=true
STATIC_CACHE_MAX_AGE=31536000  # 1 year

# Security Headers
ENABLE_HELMET=true
HELMET_CSP_ENABLED=true

# =============================================================================
# API CONFIGURATION
# =============================================================================

# API Rate Limiting
API_RATE_LIMIT=1000            # Requests per hour
API_BURST_LIMIT=100            # Burst requests

# API Timeouts
API_TIMEOUT=30000              # 30 seconds
API_RETRY_ATTEMPTS=3

# =============================================================================
# BACKUP AND MAINTENANCE
# =============================================================================

# Database Backup Configuration
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="System maintenance in progress"

# =============================================================================
# REPLIT SPECIFIC CONFIGURATION
# =============================================================================

# Replit Environment Detection
REPLIT=false                   # Set to true when running on Replit
REPL_SLUG=csm-smart-connect
REPL_OWNER=your-replit-username

# =============================================================================
# NOTES AND WARNINGS
# =============================================================================

# SECURITY WARNINGS:
# 1. Never commit this file with real values to version control
# 2. Use strong, unique passwords and secrets
# 3. Rotate API keys regularly
# 4. Use environment-specific configurations
# 5. Enable HTTPS in production (set SESSION_SECURE=true)

# REQUIRED FOR BASIC FUNCTIONALITY:
# - DATABASE_URL or individual POSTGRES_* variables
# - SESSION_SECRET
# - AYRSHARE_API_KEY (for social media features)

# OPTIONAL BUT RECOMMENDED:
# - GEMINI_API_KEY (for AI features)
# - SUPABASE_* (if using Supabase instead of direct PostgreSQL)
# - SMTP_* (for email notifications)

# FOR PRODUCTION DEPLOYMENT:
# - Set NODE_ENV=production
# - Use HTTPS URLs for CLIENT_URL and SERVER_URL
# - Set SESSION_SECURE=true
# - Configure proper CORS_ORIGIN
# - Enable security features (HELMET, rate limiting)
